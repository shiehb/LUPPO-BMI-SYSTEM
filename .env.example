NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Email delivery for new user credentials (uses Resend — https://resend.com)
RESEND_API_KEY=re_your_api_key_here
# Dev: use onboarding@resend.dev (only delivers to your Resend-verified email)
# Prod: verify your domain in Resend dashboard first, then use noreply@yourdomain.com
EMAIL_FROM=onboarding@resend.dev
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry — error monitoring & alerting (https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
